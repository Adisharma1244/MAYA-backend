{
  "expo": {
    "name": "Wildcard",
    "slug": "wildcard-maya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/newlogo.jpeg",
    "scheme": "Wildcard",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/newlogo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/newlogo.jpeg"
      },
      "package": "com.adisharma111.MAYA"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/newlogo.jpeg"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4939123118848020~3081594567",
          "iosAppId": "ca-app-pub-4939123118848020~3081594567"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ed04e8a-136a-4d43-bdd8-c96cdeb914ee"
      }
    }
  }
}
